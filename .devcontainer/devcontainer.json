{
  "name": "Go Dev Container",
  "dockerComposeFile": [
    "../docker-compose.yml",
    "../example-application/docker-compose.yml",
    "../.docker-compose-services-override.yml",
    "../.docker-compose-networks-override.yml",
    "../.docker-compose-gpu-override.yml",
    "./docker-compose.yml",
    "./docker-compose-vscode.yml"
  ],
  "runServices": [
    "dev"
  ],
  "containerEnv": {
    // "MAKE_DEV_ON_START": "true",
    "MAKE_TESTS_ON_START": "false",
    "FLUTTER_ROOT": "${localWorkspaceFolder}/.containers/android-studio/flutter",
    "DEV_GOOGLE_CLOUD_PROJECT_ID": "moov-dev-439608",
    "LOCAL_ANDROID_STUDIO_CACHES_REFRESH": "true",
    "LOCAL_ANDROID_STUDIO_CONTAINER_CACHE": "${localWorkspaceFolder}/.containers/android-studio",
    "LOCAL_ANDROID_STUDIO_ON_START": "true",
    "LOCAL_CLARINET_DEVNET_CACHES_REFRESH": "true",
    "LOCAL_CONTAINER_INSTALL": "true",
    "LOCAL_ROBOTFRAMEWORK_CACHES_REFRESH": "true"
  },
  "service": "dev",
  "initializeCommand": "${localWorkspaceFolder}/.devcontainer/initialize-cmd.sh",
  "workspaceFolder": "${localWorkspaceFolder}",
  "customizations": {
    "vscode": {
      "files.hotExit": "onExitAndWindowClose",
      "window.customTitleBarVisibility": "windowed",
      "remote.portsAttributes": {
        "2375": {
          "label": "Devcontainer - Host - Docker Socket",
          "protocol": "http",
          "onAutoForward": "silent"
        },
        "2376": {
          "label": "Clarinet - Devnet - Docker Socket",
          "protocol": "http",
          "onAutoForward": "silent"
        },
        "3000": {
          "label": "Application UI - Debug",
          "protocol": "http",
          "onAutoForward": "silent"
        },
        "8080": {
          "label": "Application Backend - Container",
          "protocol": "http",
          "onAutoForward": "silent"
        },
        "8088": {
          "label": "Application Tests - Report",
          "onAutoForward": "silent"
        },
        "8888": {
          "label": "Application Backend - Debug",
          "onAutoForward": "silent"
        },
        "4000": {
          "label": "Firebase Emulator UI",
          "protocol": "http",
          "onAutoForward": "silent"
        },
        "4400": {
          "label": "Firebase Emulator Hub",
          "onAutoForward": "silent"
        },
        "4500": {
          "label": "Firebase reserved 0",
          "onAutoForward": "silent"
        },
        "5001": {
          "label": "Firebase Functions",
          "onAutoForward": "silent"
        },
        "4723": {
          "label": "Appium - Android Debug Bridge - Android",
          "onAutoForward": "silent"
        },
        "5037": {
          "label": "ADB - adb server - Studio - Android",
          "onAutoForward": "silent"
        },
        "6037": {
          "label": "ADB - Android Debug Bridge - Appium - Android",
          "onAutoForward": "silent"
        },
        "7037": {
          "label": "ADB - Vegito - Application Mobile - Android",
          "onAutoForward": "silent"
        },
        "6900": {
          "label": "VNC - X server - Studio - Android",
          "onAutoForward": "silent"
        },
        "7900": {
          "label": "VNC - X server - Appium - Android",
          "onAutoForward": "silent"
        },
        "8900": {
          "label": "VNC - X server - Application Mobile - Android",
          "onAutoForward": "silent"
        },
        "6901": {
          "label": "Xpra - X server - Studio - Android",
          "onAutoForward": "silent"
        },
        "7901": {
          "label": "Xpra - X server - Appium - Android",
          "onAutoForward": "silent"
        },
        "8901": {
          "label": "Xpra - X server - Application Mobile - Android",
          "onAutoForward": "silent"
        },
        "8200": {
          "label": "Vault API",
          "onAutoForward": "silent"
        },
        "8201": {
          "label": "Vault Cluster",
          "onAutoForward": "silent"
        },
        "8085": {
          "label": "Firebase Pub/Sub Emulator",
          "onAutoForward": "silent"
        },
        "8090": {
          "label": "Firebase Firestore",
          "onAutoForward": "silent"
        },
        "9000": {
          "label": "Firebase Database",
          "onAutoForward": "silent"
        },
        "9005": {
          "label": "Firebase CLI Login",
          "onAutoForward": "silent"
        },
        "9099": {
          "label": "Firebase Authentication",
          "onAutoForward": "silent"
        },
        "9100": {
          "label": "Flutter and Dart DevTools - Studio - Android",
          "onAutoForward": "silent"
        },
        "9150": {
          "label": "Firebase Reserved 1",
          "onAutoForward": "silent"
        },
        "9199": {
          "label": "Firebase Storage",
          "onAutoForward": "silent"
        },
        "9299": {
          "label": "Firebase (triggers)",
          "onAutoForward": "silent"
        }
      },
      "extensions": [
        "4ops.terraform",
        "alexisvt.flutter-snippets",
        "bierner.markdown-mermaid",
        "ChFlick.firecode",
        "circlecodesolution.ccs-flutter-color",
        "codeium.codeium",
        "dart-code.dart-code",
        "dart-code.dart-test-adapter",
        "dart-code.flutter",
        "dbaeumer.vscode-eslint",
        "diemasmichiels.emulate",
        "esbenp.prettier-vscode",
        "genieai.chatgpt-vscode",
        "github.vscode-github-actions",
        "golang.go",
        "googlecloudtools.cloudcode",
        "gornivv.vscode-flutter-files",
        "hasanakg.firebase-snippets",
        "hashicorp.hcl",
