        "me-dutour-mathieu.vscode-github-actions",
        "ms-azuretools.vscode-docker",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "msjsdiag.vscode-react-native",
        "Nash.awesome-flutter-snippets",
        "openai.chatgpt",
        "pjmiravalle.terraform-advanced-syntax-highlighting",
        "pkief.material-icon-theme",
        "redhat.vscode-xml",
        "redhat.vscode-yaml",
        "robocorp.robotframework-lsp",
        "shd101wyy.markdown-preview-enhanced",
        "standard.vscode-standard",
        "toba.vsfire",
        "tylerharris.terraform-link-docs",
        "cosmicsarthak.cosmicsarthak-neon-theme",
        "xynny.hackerred"
      ]
    },
    "github-actions.workflows.pinned.workflows": [
      ".github/workflows/application-main-release.yml",
      ".github/workflows/application-dev-latest.yml",
    ],
    "robotcode.disableExtension": true
  }
}